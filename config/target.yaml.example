# ============================================================
# WAF-Fuzzer Multi-Agent 配置文件 (示例)
# 复制为 target.yaml 并填入实际值后使用
# ============================================================

# 全局 LLM 配置
llm:
  provider: "openai"
  api_key: "your-api-key-here"
  model: "mimo-v2.5-pro"
  base_url: "https://token-plan-cn.xiaomimimo.com/v1"

# Fuzzing 全局参数
fuzzing:
  max_iterations: 20
  batch_size: 5
  concurrency: 5
  request_timeout: 15
  early_stop_on_all_blocked: 5
  solver_dimensions:
    - semantic
    - protocol
    - performance
    - topology
  dimension_switch_threshold: 3

# OOB (Out-of-Band) 回调服务器配置
# 用于 log4j / 反序列化等需要外部回调确认的漏洞类型
oob:
  server: "oob.example.com"
  poll_api: "https://oob.example.com/api/poll"
  api_key: ""
  poll_interval_ms: 2000
  poll_timeout_ms: 30000

# 入口 URL 列表
# Crawler 会从这些 URL 开始爬取，自动发现表单并推断注入点
entry_urls:
  - "http://192.168.1.100:81/"
