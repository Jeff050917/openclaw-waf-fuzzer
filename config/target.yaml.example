# ============================================================
# WAF-Fuzzer Multi-Agent 配置文件 (示例)
# 复制为 target.yaml 并填入实际值后使用
# ============================================================

# 全局 LLM 配置
llm:
  provider: "openai"
  api_key: "your-api-key-here"
  model: "mimo-v2.5-pro"
  base_url: "https://token-plan-cn.xiaomimimo.com/v1"

# Fuzzing 全局参数
fuzzing:
  max_iterations: 20
  batch_size: 5
  concurrency: 5
  request_timeout: 15
  early_stop_on_all_blocked: 5
  solver_dimensions:
    - semantic
    - protocol
    - performance
    - topology
  dimension_switch_threshold: 3

# OOB (Out-of-Band) 回调配置
# 用于 log4j / 反序列化等需要外部回调确认的漏洞类型
#
# 方式 1：dnslog.cn（免费，无需注册，自动获取临时域名）
oob:
  provider: "dnslog"

# 方式 2：ceye.io（更稳定，需注册）
# oob:
#   provider: "ceye"
#   api_token: "your-ceye-api-token"
#   identifier: "your-ceye-identifier"

# 方式 3：手动指定（兼容旧配置）
# oob:
#   server: "your-oob-server.com"
#   poll_api: "https://your-oob-server.com/api/poll"

# ============================================================
# 方式一：按漏洞类型配置（推荐）
# 直接指定每个漏洞类型的 WAF/无-WAF 靶场 URL
# 系统自动获取页面表单、检测注入参数，无需全站爬取
# ============================================================
targets:
  sqli:
    waf: "http://111.230.233.61:81/vulnerabilities/sqli/"
    no_waf: "http://111.230.233.61:8111/vulnerabilities/sqli/"
  cmdi:
    waf: "http://111.230.233.61:81/vulnerabilities/cmdi/"
    no_waf: "http://111.230.233.61:8111/vulnerabilities/cmdi/"
  log4j: {}  # 暂不测试

# ============================================================
# 方式二：入口 URL 列表（旧格式，兼容）
# 1 个 URL → 黑盒模式（单独测试）
# 2 个 URL → 对比模式（第一个 = WAF 靶场，第二个 = 无 WAF 靶场）
# ============================================================
# entry_urls:
#   - "http://192.168.1.100:81/"
#   - "http://192.168.1.100:82/"
